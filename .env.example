# Backroom — Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ============================================
# DATABASE (Postgres)
# ============================================
POSTGRES_USER=backroom
POSTGRES_PASSWORD=backroom_dev_password
POSTGRES_DB=backroom
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection URL (used by backend services)
DATABASE_URL=postgres://backroom:backroom_dev_password@localhost:5432/backroom

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ============================================
# JWT / AUTH
# ============================================
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_a_32_byte_hex_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# TURN / STUN (coturn)
# ============================================
TURN_URL=turn:localhost:3478
STUN_URL=stun:localhost:3478
TURN_USERNAME=backroom
TURN_CREDENTIAL=backroom_turn_secret
# For REST API credential generation:
TURN_LONG_TERM_SECRET=CHANGE_ME_coturn_static_auth_secret

# ============================================
# FIREBASE / FCM (Push Notifications)
# ============================================
# Download service account from Firebase Console > Project Settings > Service Accounts
# Place the JSON file at: backend/rest-api/firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
FCM_PROJECT_ID=your-firebase-project-id

# ============================================
# M-PESA (Safaricom Daraja API)
# ============================================
# Get credentials from https://developer.safaricom.co.ke/
MPESA_ENVIRONMENT=sandbox
# Options: sandbox, production

# Consumer Key and Secret from Daraja portal
MPESA_CONSUMER_KEY=CHANGE_ME_your_consumer_key
MPESA_CONSUMER_SECRET=CHANGE_ME_your_consumer_secret

# Your Paybill or Till Number
MPESA_SHORTCODE=174379

# Lipa Na M-Pesa Online Passkey (from Daraja)
MPESA_PASSKEY=CHANGE_ME_your_passkey

# Callback URLs (must be HTTPS and publicly accessible)
# Use ngrok for local development: ngrok http 8080
MPESA_CALLBACK_URL=https://your-domain.com/api/v1/mpesa/callback
MPESA_TIMEOUT_URL=https://your-domain.com/api/v1/mpesa/timeout
MPESA_RESULT_URL=https://your-domain.com/api/v1/mpesa/result

# Subscription Pricing (in KES)
SUBSCRIPTION_MONTHLY_PRICE=500
SUBSCRIPTION_YEARLY_PRICE=5000
SUBSCRIPTION_TRIAL_DAYS=7

# ============================================
# APP CONFIG
# ============================================
NODE_ENV=development
PORT=8080
WS_PORT=8443
LOG_LEVEL=debug

# ============================================
# OBSERVABILITY (optional for dev)
# ============================================
SENTRY_DSN=
PROMETHEUS_ENABLED=false

